# =============================================================
# .env.example
# Copy to .env and fill in values before deploying.
# NEVER commit .env to git.
# =============================================================

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# S3
S3_RAW_BUCKET=veloquity-raw-dev-123456789012

# Database (fetched from Secrets Manager at runtime — fill for local dev only)
DB_HOST=veloquity-dev.xxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=veloquity
DB_USER=veloquity_user
DB_PASSWORD=changeme_local_only
DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:veloquity/dev/db-credentials

# Bedrock
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_LLM_MODEL=us.amazon.nova-pro-v1:0

# Lambda names (for API → Lambda invocation)
REASONING_LAMBDA_NAME=veloquity-reasoning-dev

# Output
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
REPORT_BUCKET=veloquity-reports-dev-123456789012

# Evidence Intelligence thresholds
EMBEDDING_CACHE_TTL_DAYS=30
CONFIDENCE_AUTO_REJECT=0.4
CONFIDENCE_AUTO_ACCEPT=0.6
MIN_CLUSTER_SIZE=5
MIN_COSINE_SIMILARITY=0.75

# Governance
STALE_SIGNAL_DAYS=30
SIGNAL_PROMOTION_FREQ=10
CACHE_HIT_RATE_ALERT=0.40
